{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173"],
      "port": 5173,
      "cwd": "app"
    },
    {
      "name": "polish",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'application/javascript','svg':'image/svg+xml','png':'image/png','jpg':'image/jpeg','json':'application/json'};h.createServer((q,r)=>{let u=q.url==='/'?'/index-pl.html':q.url;let fp=p.join('.',decodeURIComponent(u));f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}let ext=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':(m[ext]||'application/octet-stream')+'; charset=utf-8'});r.end(d)})}).listen(5174,()=>console.log('Serving on http://localhost:5174'))"],
      "port": 5174
    }
  ]
}
